{
  "version": 6,

  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20
  },

  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",

      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "IGECKO_ENABLE_SANITIZERS": "ON",
        "IGECKO_ENABLE_CLANG_TIDY": "ON"
      }
    },

    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",

      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "IGECKO_ENABLE_LTO": "ON"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },

    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}
