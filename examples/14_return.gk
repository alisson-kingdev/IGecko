package main;

func getValue() {
    return 42;
}

func getString() {
    return "Hello, Return!";
}

func isPositive(n) {
    if (n > 0) {
        return true;
    } else {
        return false;
    }
}

func main() {
    print("getValue(): " + getValue());
    print("getString(): " + getString());
    print("isPositive(10): " + isPositive(10));
    print("isPositive(-5): " + isPositive(-5));
}

main();
